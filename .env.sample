# cal-cli configuration

# Auth (tried in order: refresh_token > token > oauth > cookie)

# 1. Refresh token from MSAL cache (auto-renews, no browser required)
# Extract from browser's localStorage: Application > Local Storage > login.windows.net
# Key: <homeAccountId>-login.windows.net-refreshtoken-<clientId>--
# Copy the "secret" field value (starts with "1.AQ...")
OUTLOOK_REFRESH_TOKEN=""
# Tenant ID from homeAccountId (the part after the dot, or "realm" in the IdToken entry)
OUTLOOK_TENANT_ID=""
# Client ID (default is OWA's public client — only override if using your own app registration)
OUTLOOK_CLIENT_ID="9199bf20-a13f-4107-85dc-02114787ef48"

# 2. JWT token from Outlook Web (~65 min lifetime, full Outlook permissions)
# Get from DevTools (F12) > Network > any request to outlook.office.com > Authorization header
# Strip the "Bearer " prefix, just the eyJ... part
OUTLOOK_TOKEN=""

# 3. OAuth via get-token (0 = disabled, 1 = try get-token, fall back to cookie)
# Requires get-token on PATH with Calendars.ReadWrite scope
use_oauth=0

# 4. Session cookie from outlook.office.com (full Cookie header from DevTools)
OUTLOOK_COOKIE=""

# Display
default_timezone="W. Europe Standard Time"
debug=0
