# cal-cli configuration

# Auth (tried in order: token > oauth > cookie)

# 1. JWT token from Outlook Web (~65 min lifetime, full Outlook permissions)
# Get from DevTools (F12) > Network > any request to outlook.office.com > Authorization header
# Strip the "Bearer " prefix, just the eyJ... part
OUTLOOK_TOKEN=""

# 2. OAuth via get-token (0 = disabled, 1 = try get-token, fall back to cookie)
# Requires get-token on PATH with Calendars.ReadWrite scope
use_oauth=0

# 3. Session cookie from outlook.office.com (full Cookie header from DevTools)
OUTLOOK_COOKIE=""

# Display
default_timezone="W. Europe Standard Time"
debug=0
